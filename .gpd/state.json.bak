{
  "project_reference": {
    "project_md_updated": "2026-03-23",
    "core_research_question": "What is the optimal computational architecture for real-time CF-LIBS multi-element plasma diagnostics via GPU acceleration?",
    "current_focus": "Phase 1 \u2014 Physics Formalization"
  },
  "project_contract": {
    "schema_version": 1,
    "scope": {
      "question": "What is the optimal computational architecture for real-time Calibration-Free LIBS multi-element plasma diagnostics, and how do GPU-accelerated implementations of the Voigt profile, Boltzmann fitting, iterative solver, manifold lookup, and batch forward model compare to existing tools?",
      "in_scope": [
        "GPU-accelerated Voigt profile via Faddeeva/Humlicek/Zaghloul with JAX vmap",
        "Vectorized Boltzmann plot fitting across elements via batched matmul",
        "Anderson-accelerated Saha-Boltzmann iterative solver",
        "Softmax closure for composition simplex constraint",
        "Batch forward model with vmap over spectra",
        "Before/after benchmarks on V100S GPUs (vasp-01/02/03)",
        "Publication-quality paper targeting JQSRT",
        "Beamer slide deck for 20-min talk",
        "arXiv submission (physics.comp-ph primary, cs.CE secondary)"
      ],
      "out_of_scope": [
        "Non-LTE plasma modeling extensions",
        "Multi-zone plasma models",
        "Neural network surrogate models (PINN)",
        "Bayesian inference acceleration",
        "Streaming/temporal LIBS analysis acceleration",
        "Porting to non-NVIDIA GPUs (AMD ROCm, Intel)",
        "MPI-distributed multi-GPU scaling"
      ],
      "unresolved_questions": [
        "Optimal Anderson acceleration mixing depth M for CF-LIBS Saha-Boltzmann coupling",
        "Whether FAISS GPU index outperforms CPU at the 1M-100M point manifold scales typical in CF-LIBS",
        "Whether JIT compilation overhead is amortized for typical LIBS batch sizes (100-1000 spectra)"
      ]
    },
    "context_intake": {
      "must_read_refs": [
        "ref-exojax",
        "ref-helosk",
        "ref-zaghloul2024",
        "ref-evans2018"
      ],
      "must_include_prior_outputs": [
        "cflibs/benchmark/unified.py \u2014 existing benchmark framework",
        "cflibs/manifold/ \u2014 existing JAX manifold generator"
      ],
      "user_asserted_anchors": [
        "No existing GPU-accelerated CF-LIBS code \u2014 this is novel",
        "ExoJAX proved JAX spectral models work on GPU for exoplanets, not LIBS",
        "Zaghloul 2024 provides SOTA Voigt algorithm"
      ],
      "known_good_baselines": [
        "Current CPU implementation in cflibs/ (58K LOC production pipeline)",
        "Existing benchmark framework in cflibs/benchmark/unified.py"
      ],
      "context_gaps": [
        "NotebookLM KB CF-LIBS Algorithmic Optimization Research (ID: 9170d55e) has Gemini Deep Research report \u2014 not yet ingested into GPD"
      ],
      "crucial_inputs": [
        "7 figures: pipeline architecture, Voigt throughput, Boltzmann speedup, Anderson convergence, FAISS latency, batch scaling, end-to-end benchmark",
        "All benchmark data MUST come from actual execution on V100S GPUs \u2014 NEVER fabricate results",
        "Conventions: T [K], n_e [cm^-3], C_i dimensionless sum-to-1, lambda [nm], E [eV], A_ki [s^-1]"
      ]
    },
    "approach_policy": {
      "formulations": [
        "JAX jit/vmap for GPU kernel acceleration",
        "Faddeeva function for Voigt profile via scipy.special.wofz reference, Humlicek W4 or Zaghloul 2024 Chebyshev for GPU",
        "Weighted least-squares Boltzmann fitting with batched matmul",
        "Anderson acceleration with configurable mixing depth M=1..10",
        "Softmax parameterization for composition closure (compare with ILR transform)"
      ],
      "allowed_estimator_families": [
        "direct GPU kernel benchmarks",
        "end-to-end pipeline timing"
      ],
      "forbidden_estimator_families": [
        "simulated or fabricated benchmark data"
      ],
      "allowed_fit_families": [
        "physically motivated Voigt profile models",
        "LTE Boltzmann population models"
      ],
      "forbidden_fit_families": [
        "ad-hoc curve fits without physical basis"
      ],
      "stop_and_rethink_conditions": [
        "GPU overhead exceeds compute savings for typical batch sizes",
        "Accuracy degradation exceeds 1e-6 relative error vs reference Voigt implementation",
        "Anderson acceleration diverges for standard CF-LIBS parameter ranges"
      ]
    },
