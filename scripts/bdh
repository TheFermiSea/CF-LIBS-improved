#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

cat >&2 <<'EOF'
scripts/bdh: BeadHub is retired for this repository.
scripts/bdh: use native `bd` commands directly.
EOF

if [[ $# -gt 0 && "$1" == :* ]]; then
    case "$1" in
        :policy)
            shift
            exec bd prime "$@"
            ;;
        :status)
            shift
            exec bd status "$@"
            ;;
        :force-sync)
            shift
            exec bd dolt push "$@"
            ;;
        :help)
            shift
            exec bd help "$@"
            ;;
        *)
            printf 'scripts/bdh: unsupported retired BeadHub command: %s\n' "$1" >&2
            printf 'scripts/bdh: try `bd prime`, `bd ready`, `bd status`, or `bd --help`.\n' >&2
            exit 2
            ;;
    esac
fi

exec bd "$@"
